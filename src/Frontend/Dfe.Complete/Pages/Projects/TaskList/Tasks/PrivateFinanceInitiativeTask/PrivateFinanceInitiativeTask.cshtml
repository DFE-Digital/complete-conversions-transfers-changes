@page "/projects/{projectId}/tasks/private_finance_initiative"
@using Dfe.Complete.Utils
@inject Microsoft.Extensions.Configuration.IConfiguration _configuration
@model Dfe.Complete.Pages.Projects.TaskList.Tasks.PrivateFinanceInitiativeTask.PrivateFinanceInitiativeTaskModel
@{
    Layout = "_ProjectTaskLayout";
    ViewData["Title"] = Model.TaskIdentifier.ToDisplayDescription();
}
@section TaskHeaderHintSection {
    <div class="govuk-hint">
        <p>This task is only needed for schools with a private finance initiative (PFI) contract.</p>
        <p>Full guidance on handling this can be accessed here: <external-link href="@_configuration["ExternalLinks:PrivateFinanceInitiativeGuidance"]">Private Finance Initiative (PFI)</external-link>.</p>
    </div>
}
@section TaskSection {

    <form method="post">
        <input type="hidden" asp-for="TasksDataId" />

        <govuk-checkboxes name="options">
            <govuk-checkboxes-fieldset>
                <govuk-checkboxes-fieldset-legend>
                </govuk-checkboxes-fieldset-legend>
                <govuk-checkboxes-item data-cy="not-applicable" id="not-applicable" asp-for="@Model.NotApplicable" value="true" name="@nameof(Model.NotApplicable)" checked="@Model.NotApplicable">
                    <b>Not applicable</b>
                </govuk-checkboxes-item>
            </govuk-checkboxes-fieldset>
        </govuk-checkboxes>

        <h2 class="govuk-heading-l">Clear and sign private finance initiative agreement</h2>

        <div class="govuk-hint">
            <p>A private finance initiative agreement should include these clauses:</p>
        </div>

        <govuk-radios name="@nameof(Model.SupplementaryFundingAgreementPfiClausesInserted)" asp-for="@Model.SupplementaryFundingAgreementPfiClausesInserted">
            <govuk-radios-fieldset>
                <govuk-radios-fieldset-legend class="govuk-fieldset__legend--m">
                    supplementary funding agreement has PFI clauses inserted?
                </govuk-radios-fieldset-legend>
                <govuk-radios-item data-cy="supplementary-funding-agreement-pfi-clauses-inserted-yes" value="true" checked="@Model.SupplementaryFundingAgreementPfiClausesInserted">Yes</govuk-radios-item>
                <govuk-radios-item data-cy="supplementary-funding-agreement-pfi-clauses-inserted-no" value="false" checked="@(Model.SupplementaryFundingAgreementPfiClausesInserted == false)">No</govuk-radios-item>
            </govuk-radios-fieldset>
        </govuk-radios>

        <govuk-radios name="@nameof(Model.MasterFundingAgreementPfiClausesInserted)" asp-for="@Model.MasterFundingAgreementPfiClausesInserted">
            <govuk-radios-fieldset>
                <govuk-radios-fieldset-legend class="govuk-fieldset__legend--m">
                    master funding agreement has PFI clauses inserted?
                </govuk-radios-fieldset-legend>
                <govuk-radios-item data-cy="master-funding-agreement-pfi-clauses-inserted-yes" value="true" checked="@Model.MasterFundingAgreementPfiClausesInserted">Yes</govuk-radios-item>
                <govuk-radios-item data-cy="master-funding-agreement-pfi-clauses-inserted-no" value="false" checked="@(Model.MasterFundingAgreementPfiClausesInserted == false)">No</govuk-radios-item>
            </govuk-radios-fieldset>
        </govuk-radios>

        <govuk-checkboxes name="options">
            <govuk-checkboxes-fieldset>
                <govuk-checkboxes-fieldset-legend>
                </govuk-checkboxes-fieldset-legend>
                <govuk-checkboxes-item data-cy="received-checkbox" id="@nameof(Model.Received)" asp-for="@Model.Received" value="true" name="@nameof(Model.Received)" checked="@Model.Received">
                    <b>Received</b>
                </govuk-checkboxes-item>
                <govuk-checkboxes-item data-cy="documents-sent-to-sopu-for-clearance-checkbox" id="@nameof(Model.DocumentsSentToSOPUForClearance)" asp-for="@Model.DocumentsSentToSOPUForClearance" value="true" name="@nameof(Model.DocumentsSentToSOPUForClearance)" checked="@Model.DocumentsSentToSOPUForClearance">
                    <b>Documents sent to SOPU for PFI clearance</b>
                </govuk-checkboxes-item>
                <govuk-checkboxes-item data-cy="cleared-checkbox" id="@nameof(Model.Cleared)" asp-for="@Model.Cleared" value="true" name="@nameof(Model.Cleared)" checked="@Model.Cleared">
                    <b>Cleared</b>
                </govuk-checkboxes-item>
                <govuk-checkboxes-item data-cy="draft-saved-in-trust-sharepoint-folder-checkbox" id="@nameof(Model.DraftSaved)" asp-for="@Model.DraftSaved" value="true" name="@nameof(Model.DraftSaved)" checked="@Model.DraftSaved">
                    <b>Draft saved in trust's SharePoint folder</b>
                </govuk-checkboxes-item>
                <govuk-checkboxes-item data-cy="signed-by-all-stakeholders-checkbox" id="@nameof(Model.SignedByAllStakeHolders)" asp-for="@Model.SignedByAllStakeHolders" value="true" name="@nameof(Model.SignedByAllStakeHolders)" checked="@Model.SignedByAllStakeHolders">
                    <b>Signed by all stakeholders</b>
                </govuk-checkboxes-item>
                <govuk-checkboxes-item data-cy="final-version-saved-in-school-and-trust-sharepoint-folder-checkbox" id="@nameof(Model.FinalVersionSavedInSharepointFolder)" asp-for="@Model.FinalVersionSavedInSharepointFolder" value="true" name="@nameof(Model.FinalVersionSavedInSharepointFolder)" checked="@Model.FinalVersionSavedInSharepointFolder">
                    <b>Final version saved in school and trust's SharePoint folder</b>
                </govuk-checkboxes-item>
            </govuk-checkboxes-fieldset>
        </govuk-checkboxes>

        @await Html.PartialAsync("_TaskSaveAndReturn", new TaskSaveAndReturnModel(Model.Project, Model.CurrentUserTeam))
    </form>
}
