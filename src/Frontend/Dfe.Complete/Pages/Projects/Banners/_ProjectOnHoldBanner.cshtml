@using Dfe.Complete.Constants
@using GovUk.Frontend.AspNetCore.TagHelpers
@using Dfe.Complete.Pages.Projects.ProjectView
@model ProjectLayoutModel

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <govuk-notification-banner>
            <govuk-notification-banner-title>
                Important
            </govuk-notification-banner-title>
            <h3>Project on hold</h3>
            <p>The project was put on hold on @Model.Project.OnHoldDate.ToDateString().</p>
            <p>You can <a href="@string.Format(RouteConstants.ProjectResumeConfirm, Model.ProjectId)">resume the project</a> if you are ready to continue with it.</p>
        </govuk-notification-banner>
    </div>
</div>