@using GovUk.Frontend.AspNetCore.TagHelpers
@using Dfe.Complete.Pages.Projects.ProjectView
@model ProjectLayoutModel

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <govuk-notification-banner class="govuk-notification-banner">
            <govuk-notification-banner-title>
                Important
            </govuk-notification-banner-title>
            <p>This project's Directive Academy Order was revoked on @Model.DaoRevocation?.DateOfDecision.ToDateString().</p>
            <p>Only Service Support team members can make changes to this project.</p>
        </govuk-notification-banner>
    </div>
</div>